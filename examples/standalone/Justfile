set dotenv-load

# ──────────────────────────────────────────────
# OpenAI examples
# ──────────────────────────────────────────────

# Non-streaming generation via OpenAI
openai-generate:
	cargo run --bin openai-generate

# Streaming generation via OpenAI
openai-stream:
	cargo run --bin openai-stream

# Non-streaming OpenAI tool loop
openai-tool-use:
	cargo run --bin openai-tool-use

# Streaming OpenAI tool loop
openai-tool-stream:
	cargo run --bin openai-tool-stream

# Inspect OpenAI structured stream events
openai-event-inspection:
	cargo run --bin openai-event-inspection

# ──────────────────────────────────────────────
# Anthropic examples
# ──────────────────────────────────────────────

# Non-streaming generation via Anthropic
anthropic-generate:
	cargo run --bin anthropic-generate

# Streaming generation via Anthropic
anthropic-stream:
	cargo run --bin anthropic-stream

# Non-streaming Anthropic tool loop
anthropic-tool-use:
	cargo run --bin anthropic-tool-use
